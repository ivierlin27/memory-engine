# Copy to lxc.env (gitignored) and fill. Sourced by provision-lxc-on-proxmox.sh
export CT_ID=200
export CT_HOSTNAME=memory-engine
export CT_CORES=4
export CT_MEMORY_MB=6144
export CT_SWAP_MB=4096
export CT_DISK_GB=80
export CT_BRIDGE=vmbr0
export CT_STORAGE=local-lvm
# Full path from: pveam available | grep ubuntu-24.04
export UBUNTU_TEMPLATE="local:vztmpl/ubuntu-24.04-standard_24.04-2_amd64.tar.zst"
export LXC_IP=192.168.1.50
export LXC_NETMASK=255.255.255.0
export LXC_GATEWAY=192.168.1.1
export PIHOLE_DNS_IP=192.168.1.X
