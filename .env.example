POSTGRES_PASSWORD=
# Django secret for Khoj (generate: openssl rand -hex 32)
KHOJ_DJANGO_SECRET_KEY=
# Used by Khoj and mem0/mem0-api-server.
# Prefer the LiteLLM/model-gateway key when MEMORY_ENGINE_LLM_BASE_URL is set.
OPENAI_API_KEY=
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=
N8N_ENCRYPTION_KEY=
PLANKA_SECRET_KEY=

LXC_IP=192.168.1.50
# Legacy fallback for direct LM Studio usage. Wrong: LM_STUDIO_HOST=LXC_IP=192.168...
LM_STUDIO_HOST=
LM_STUDIO_PORT=1234
LM_STUDIO_EMBED_PORT=1235
DOMAIN=dev-path.org

LLM_MODEL=qwen2.5-32b-instruct
EMBED_MODEL=nomic-embed-text

# Optional — Khoj script scripts/sync-khoj-chat-models.sh (defaults are fine)
# KHOJ_LMSTUDIO_API_NAME=Model Gateway (synced)
# KHOJ_SYNC_MAX_PROMPT_SIZE=32768

PLANKA_API_TOKEN=
PLANKA_INBOX_LIST_ID=
PLANKA_REJECTED_LIST_ID=

# Optional — Mem0 user_id string for n8n workflows ($env.MEMORY_ENGINE_USER_ID)
# MEMORY_ENGINE_USER_ID=memory-engine

# Preferred OpenAI-compatible gateway / route config. Leave empty to fall back
# to LM_STUDIO_HOST:LM_STUDIO_PORT for chat completions.
# MEMORY_ENGINE_LLM_BASE_URL=https://model-gateway.dev-path.org/v1
# MEMORY_ENGINE_STRONG_MODEL=homelab-strong
# MEMORY_ENGINE_FAST_MODEL=homelab-fast
# MEMORY_ENGINE_COMPILER_DAYS=7
# MEMORY_ENGINE_COMPILER_SCOPE=weekly
# MEMORY_ENGINE_COMPILED_DIR=obsidian_vault/compiled/current
# MEMORY_ENGINE_COMPILER_PRINCIPAL=system:wiki-compiler
# MEMORY_ENGINE_CONTRADICTION_DAYS=14
# MEMORY_ENGINE_CONTRADICTION_PRINCIPAL=system:contradiction-scan

# Optional — n8n workflow URLs (defaults are set in docker-compose.yml). Uncomment if needed:
# Same Docker network as Mem0 (default http://mem0:8000):
# MEMORY_ENGINE_MEM0_URL=http://mem0:8000
# Planka API base URL. Default is https://planka.${DOMAIN} (matches Planka BASE_URL / NPM).
# If n8n cannot reach that URL from inside Docker (hairpin DNS), use the internal API instead:
# MEMORY_ENGINE_PLANKA_URL=http://planka:1337
# Optional review / human-gate columns for orchestration:
# PLANKA_REVIEW_LIST_ID=
# PLANKA_NEEDS_HUMAN_LIST_ID=
# PLANKA_PLAN_READY_LIST_ID=
# PLANKA_APPROVED_LIST_ID=
# PLANKA_AUTHOR_REVIEW_LIST_ID=
# AUTHOR_AGENT_PLAN_WEBHOOK_URL=
# AUTHOR_AGENT_EXECUTE_WEBHOOK_URL=
# REVIEW_AGENT_WEBHOOK_URL=
# HUMAN_REVIEW_WEBHOOK_URL=

NTFY_TOPIC=
PUSHOVER_USER_KEY=
PUSHOVER_API_TOKEN=

SEARXNG_URL=https://search.dev-path.org

# Optional: Mem0 API build (see docker/mem0-api-server/Dockerfile)
# MEM0_GIT_REF=main

# n8n: use false only for debugging http://<LAN-IP>:5678; use https://n8n.<domain> in production
# N8N_SECURE_COOKIE=false

# Set in docker-compose.yml (do not duplicate here): N8N_BLOCK_ENV_ACCESS_IN_NODE=false so ME workflows can use $env.* in expressions.
