POSTGRES_PASSWORD=
# Django secret for Khoj (generate: openssl rand -hex 32)
KHOJ_DJANGO_SECRET_KEY=
# Used by mem0/mem0-api-server (OpenAI-compatible); LM Studio: use lm-studio + OPENAI_BASE_URL below
OPENAI_API_KEY=lm-studio
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=
N8N_ENCRYPTION_KEY=
PLANKA_SECRET_KEY=

LXC_IP=192.168.1.50
# Machine running LM Studio (Alienware IP/DNS only). Wrong: LM_STUDIO_HOST=LXC_IP=192.168...
LM_STUDIO_HOST=
LM_STUDIO_PORT=1234
LM_STUDIO_EMBED_PORT=1235
DOMAIN=dev-path.org

LLM_MODEL=qwen2.5-32b-instruct
EMBED_MODEL=nomic-embed-text

# Optional — Khoj script scripts/sync-khoj-chat-models.sh (defaults are fine)
# KHOJ_LMSTUDIO_API_NAME=LM Studio (synced)
# KHOJ_SYNC_MAX_PROMPT_SIZE=32768

PLANKA_API_TOKEN=
PLANKA_INBOX_LIST_ID=
PLANKA_REJECTED_LIST_ID=

# Optional — Mem0 user_id string for n8n workflows ($env.MEMORY_ENGINE_USER_ID)
# MEMORY_ENGINE_USER_ID=memory-engine

# Optional — n8n workflow URLs (defaults are set in docker-compose.yml). Uncomment if needed:
# Same Docker network as Mem0 (default http://mem0:8000):
# MEMORY_ENGINE_MEM0_URL=http://mem0:8000
# Planka API base URL. Default is https://planka.${DOMAIN} (matches Planka BASE_URL / NPM).
# If n8n cannot reach that URL from inside Docker (hairpin DNS), use the internal API instead:
# MEMORY_ENGINE_PLANKA_URL=http://planka:1337

NTFY_TOPIC=
PUSHOVER_USER_KEY=
PUSHOVER_API_TOKEN=

SEARXNG_URL=https://search.dev-path.org

# Optional: Mem0 API build (see docker/mem0-api-server/Dockerfile)
# MEM0_GIT_REF=main

# n8n: use false only for debugging http://<LAN-IP>:5678; use https://n8n.<domain> in production
# N8N_SECURE_COOKIE=false
